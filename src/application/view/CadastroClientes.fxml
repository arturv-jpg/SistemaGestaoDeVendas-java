<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/24"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="application.controller.CadastroClienteController"
            style="-fx-background-color: #f4f6f8;">

    <!-- 🔹 TOPO -->
    <top>
        <HBox style="-fx-padding: 15; -fx-background-color: #ffffff;">
            <Label text="Cadastro de Clientes"
                   style="-fx-font-size: 20px; -fx-font-weight: bold;" />
        </HBox>
    </top>

    <!-- 🔹 CONTEÚDO -->
    <center>
        <VBox spacing="15" style="-fx-padding: 20;">

            <!-- 🔎 BUSCA -->
            <HBox spacing="10">
                <TextField fx:id="txtBuscar"
                           promptText="Buscar cliente..."
                           HBox.hgrow="ALWAYS"/>
                <Button text="Buscar"
                        onAction="#Buscar"
                        style="-fx-background-color: #3498db; -fx-text-fill: white;"/>
            </HBox>

            <!-- 🧾 FORMULÁRIO -->
            <GridPane hgap="10" vgap="10">

                <Label text="ID:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="txtID" GridPane.rowIndex="0" GridPane.columnIndex="1" disable="true"/>

                <Label text="Nome:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                <TextField fx:id="txtNome" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                <Label text="CPF/CNPJ:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <TextField fx:id="txtCPF" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="Email:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                <TextField fx:id="txtEmail" GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                <Label text="Status:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <ComboBox fx:id="cbStatus" GridPane.rowIndex="2" GridPane.columnIndex="1" prefWidth="150"/>

            </GridPane>

            <!-- 🔘 BOTÕES -->
            <HBox spacing="10">

                <Button text="Salvar"
                        onAction="#Salvar"
                        style="-fx-background-color: #27ae60; -fx-text-fill: white;" />

                <Button text="Novo"
                        onAction="#Novo"
                        style="-fx-background-color: #7f8c8d; -fx-text-fill: white;" />

                <Button text="Excluir"
                        onAction="#Excluir"
                        style="-fx-background-color: #e74c3c; -fx-text-fill: white;" />

            </HBox>

            <!-- 📊 TABELA -->
            <TableView fx:id="tabClientes" prefHeight="250">

                <columns>
                    <TableColumn fx:id="colID" text="ID" prefWidth="60"/>
                    <TableColumn fx:id="colNome" text="Nome" prefWidth="180"/>
                    <TableColumn fx:id="colCPF" text="CPF/CNPJ" prefWidth="150"/>
                    <TableColumn fx:id="colEmail" text="Email" prefWidth="200"/>
                    <TableColumn fx:id="colStatus" text="Status" prefWidth="100"/>
                </columns>

            </TableView>

            <!-- 📜 HISTÓRICO -->
            <Label text="Últimas compras"
                   style="-fx-font-weight: bold;"/>

            <ListView fx:id="listaHistorico" prefHeight="120"/>

        </VBox>
    </center>

</BorderPane>