<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:id="paneFundo"
            onMouseClicked="#clicarFundo"
            xmlns="http://javafx.com/javafx/24"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="application.controller.CadastroProdutoController"
            style="-fx-background-color: #f4f6f8;">

    <!-- 🔹 TOPO -->
    <top>
        <HBox style="-fx-padding: 15; -fx-background-color: #ffffff;">
            <Label text="Cadastro de Produtos"
                   style="-fx-font-size: 20px; -fx-font-weight: bold;" />
        </HBox>
    </top>

    <!-- 🔹 CONTEÚDO -->
    <center>
        <VBox spacing="15" style="-fx-padding: 20;">

            <!-- 🔍 BUSCA -->
            <HBox spacing="10">
                <TextField fx:id="txtBuscar"
                           promptText="Buscar produto..."
                           HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnBuscar"
                        text="Buscar"
                        onAction="#Pesquisar"
                        style="-fx-background-color: #3498db; -fx-text-fill: white;"/>
            </HBox>

            <!-- 💰 CUSTO / LUCRO -->
            <GridPane hgap="10" vgap="10">

                <Label text="Preço Custo:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="txtPrecoCusto" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Margem (%):" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                <TextField fx:id="txtMargemLucro" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                <Label text="Estoque Mínimo:" GridPane.rowIndex="0" GridPane.columnIndex="4"/>
                <TextField fx:id="txtEstoqueMinimo" GridPane.rowIndex="0" GridPane.columnIndex="5"/>

                <Button fx:id="btnCalcularPreco"
                        text="Calcular Preço"
                        GridPane.rowIndex="0"
                        GridPane.columnIndex="6"
                        style="-fx-background-color: #8e44ad; -fx-text-fill: white;"/>

            </GridPane>

            <!-- 📦 DADOS DO PRODUTO -->
            <GridPane hgap="10" vgap="10">

                <Label text="ID:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="txtID" disable="true" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Cod. Barras:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                <TextField fx:id="txtCodBarras" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                <Label text="Nome:" GridPane.rowIndex="0" GridPane.columnIndex="4"/>
                <TextField fx:id="txtNome" GridPane.rowIndex="0" GridPane.columnIndex="5"/>

                <Label text="Descrição:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <TextField fx:id="txtDescricao" GridPane.rowIndex="1" GridPane.columnIndex="1" GridPane.columnSpan="3"/>

                <Label text="Categoria:" GridPane.rowIndex="1" GridPane.columnIndex="4"/>
                <TextField fx:id="txtCategoria" GridPane.rowIndex="1" GridPane.columnIndex="5"/>

                <Label text="Preço Venda:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <TextField fx:id="txtPreco" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                <Label text="Qtd Atual:" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
                <TextField fx:id="txtQuantidade" disable="true" GridPane.rowIndex="2" GridPane.columnIndex="3"/>

            </GridPane>

            <!-- 🔘 BOTÕES -->
            <HBox spacing="10">

                <Button fx:id="btnSalvar"
                        text="Salvar"
                        onAction="#Salvar"
                        style="-fx-background-color: #27ae60; -fx-text-fill: white;" />

                <Button text="Novo"
                        onAction="#Novo"
                        style="-fx-background-color: #7f8c8d; -fx-text-fill: white;" />

                <Button fx:id="btnExcluir"
                        text="Excluir"
                        onAction="#Excluir"
                        style="-fx-background-color: #e74c3c; -fx-text-fill: white;" />

            </HBox>

            <!-- 📊 TABELA -->
            <TableView fx:id="tabProdutos" prefHeight="250">

                <columns>
                    <TableColumn fx:id="colID" text="ID" prefWidth="70"/>
                    <TableColumn fx:id="colNome" text="Nome" prefWidth="180"/>
                    <TableColumn fx:id="colCodBarras" text="Cod.Barras" prefWidth="140"/>
                    <TableColumn fx:id="colDescricao" text="Descrição" prefWidth="160"/>
                    <TableColumn fx:id="colCategoria" text="Categoria" prefWidth="120"/>
                    <TableColumn fx:id="colPreco" text="Preço" prefWidth="100"/>
                    <TableColumn fx:id="colQtd" text="Qtd" prefWidth="80"/>
                </columns>

            </TableView>

        </VBox>
    </center>

</BorderPane>