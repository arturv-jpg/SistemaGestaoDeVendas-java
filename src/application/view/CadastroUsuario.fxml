<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="application.controller.UsuarioController"
            prefHeight="400.0" prefWidth="600.0">

    <children>

        <Label text="Cadastro de Usuários"
               layoutX="200" layoutY="20"
               style="-fx-font-size:18px; -fx-font-weight:bold;"/>

        <!-- Nome -->
        <TextField fx:id="txtNome"
                   layoutX="50" layoutY="80"
                   prefWidth="250"
                   promptText="Nome"/>

        <!-- Login -->
        <TextField fx:id="txtLogin"
                   layoutX="50" layoutY="120"
                   prefWidth="250"
                   promptText="Login"/>

        <!-- Senha -->
        <PasswordField fx:id="txtSenha"
                        layoutX="50" layoutY="160"
                        prefWidth="250"
                        promptText="Senha"/>

        <!-- Tipo -->
        <ComboBox fx:id="cbTipo"
                  layoutX="50" layoutY="200"
                  prefWidth="250"
                  promptText="Tipo de usuário"/>

        <!-- Botões -->
        <Button text="Salvar"
                layoutX="50" layoutY="260"
                prefWidth="120"
                onAction="#salvar"/>

        <Button text="Novo"
                layoutX="180" layoutY="260"
                prefWidth="120"
                onAction="#novo"/>

    </children>
</AnchorPane>