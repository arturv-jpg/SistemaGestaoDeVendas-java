<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/24"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="application.controller.HistoricoController"
           style="-fx-background-color: #ecf0f1;">

    <VBox spacing="15"
          maxWidth="900"
          alignment="TOP_CENTER"
          style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10;">

        <!-- TÍTULO -->
        <Label text="Histórico de Processamento"
               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />

        <!-- PRODUTO -->
        <Label fx:id="lblProd"
               text="Produto"
               style="-fx-font-size: 14px; -fx-font-weight: bold;" />

        <!-- FILTROS -->
        <HBox spacing="10" alignment="CENTER">
            <VBox spacing="5">
                <Label text="Data Início"/>
                <DatePicker fx:id="dtInicio"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Data Final"/>
                <DatePicker fx:id="dtFinal"/>
            </VBox>

            <Button fx:id="btnBuscar"
                    text="Buscar"
                    style="-fx-background-color: #2980b9; -fx-text-fill: white;"
                    onAction="#buscar"/>
        </HBox>

        <!-- TABELA -->
        <TableView fx:id="tabHistorico" prefHeight="400">

            <columns>
                <TableColumn fx:id="colID" text="ID" prefWidth="60"/>
                <TableColumn fx:id="colData" text="Data" prefWidth="120"/>
                <TableColumn fx:id="colIdProd" text="ID Produto" prefWidth="100"/>
                <TableColumn fx:id="colNome" text="Nome" prefWidth="180"/>
                <TableColumn fx:id="colTipo" text="Tipo" prefWidth="100"/>
                <TableColumn fx:id="colQtd" text="Qtd" prefWidth="80"/>
            </columns>

        </TableView>

    </VBox>

</StackPane>