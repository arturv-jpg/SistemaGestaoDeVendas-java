<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/24"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="application.controller.PagamentoController"
      spacing="10"
      style="-fx-padding: 15; -fx-background-color: #ecf0f1;">

    <!-- 🔹 TÍTULO -->
    <Label text="Finalizar Venda - Pagamento"
           maxWidth="Infinity"
           alignment="CENTER"
           style="-fx-background-color: #2c3e50; -fx-text-fill: white;">
        <font>
            <Font size="16"/>
        </font>
    </Label>

    <!-- 🔹 DADOS PRINCIPAIS -->
    <GridPane hgap="10" vgap="10">

        <Label text="Total da Venda:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <Label fx:id="lblTotal" style="-fx-font-weight: bold;"
               GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Desconto (%):" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="txtDescontoPercent" prefWidth="80"
                   GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Total com Desconto:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <Label fx:id="lblTotalComDesconto" style="-fx-font-weight: bold;"
               GridPane.rowIndex="2" GridPane.columnIndex="1"/>

    </GridPane>

    <Separator/>

    <!-- 🔹 PAGAMENTOS -->
    <Label text="Formas de Pagamento" style="-fx-font-weight: bold;"/>

    <TableView fx:id="tabelaPagamentos" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colForma" text="Forma" prefWidth="150"/>
            <TableColumn fx:id="colValor" text="Valor (R$)" prefWidth="150"/>
            <TableColumn fx:id="colAcao" text="Ação" prefWidth="120"/>
        </columns>
    </TableView>

    <Button text="Adicionar Pagamento"
            onAction="#adicionarPagamento"
            style="-fx-background-color: #27ae60; -fx-text-fill: white;"/>

    <!-- 🔹 DINHEIRO / TROCO -->
    <GridPane hgap="10" vgap="10">

        <Label text="Valor Recebido (Dinheiro):"
               GridPane.rowIndex="0" GridPane.columnIndex="0"/>

        <TextField fx:id="txtValorRecebido"
                   promptText="R$"
                   GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Troco:"
               GridPane.rowIndex="0" GridPane.columnIndex="2"/>

        <Label fx:id="lblTroco"
               style="-fx-font-weight: bold;"
               GridPane.rowIndex="0" GridPane.columnIndex="3"/>

    </GridPane>

    <!-- 🔹 BOTÕES -->
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Finalizar"
                onAction="#finalizar"
                style="-fx-background-color: #2980b9; -fx-text-fill: white;"/>

        <Button text="Cancelar"
                onAction="#cancelar"
                style="-fx-background-color: #c0392b; -fx-text-fill: white;"/>
    </HBox>

</VBox>