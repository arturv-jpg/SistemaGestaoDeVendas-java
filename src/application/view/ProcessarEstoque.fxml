<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/24"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="application.controller.ProcessaEstoque">

    <!-- 🔷 TOPO -->
    <top>
        <HBox style="-fx-background-color: #1e3c72; -fx-padding: 12;">
            <Label text="Processar Estoque"
                   style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;" />
        </HBox>
    </top>

    <!-- 🔷 CONTEÚDO -->
    <center>
        <VBox spacing="15" style="-fx-padding: 15;">

            <!-- 🔍 BUSCA -->
            <HBox spacing="10">
                <TextField fx:id="txtBuscar"
                           promptText="Buscar produto..."
                           prefWidth="400"/>

                <Button fx:id="btnBuscar"
                        text="Buscar"
                        style="-fx-background-color: #3498db; -fx-text-fill: white;" />
            </HBox>

            <!-- 📦 DADOS DO PRODUTO -->
            <VBox spacing="10" style="-fx-background-color: #f4f6f7; -fx-padding: 10; -fx-background-radius: 8;">
                
                <Label text="Dados do Produto"
                       style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" />

                <HBox spacing="10">
                    <TextField fx:id="txtID" promptText="ID" disable="true" prefWidth="80"/>
                    <TextField fx:id="txtCodBarras" promptText="Código" disable="true" prefWidth="120"/>
                    <TextField fx:id="txtNome" promptText="Produto" disable="true" prefWidth="200"/>
                    <TextField fx:id="txtQtd" promptText="Qtd" prefWidth="80"/>
                </HBox>

                <!-- 🔁 OPERAÇÃO -->
                <HBox spacing="15" alignment="CENTER_LEFT">
                    <Label text="Operação:"/>

                    <RadioButton text="Entrada">
                        <toggleGroup>
                            <ToggleGroup fx:id="rdOperacao"/>
                        </toggleGroup>
                    </RadioButton>

                    <RadioButton text="Saída" toggleGroup="$rdOperacao"/>
                </HBox>

                <!-- 🔘 BOTÕES -->
                <HBox spacing="10">
                    <Button fx:id="btnProcessar"
                            text="Processar"
                            style="-fx-background-color: #2ecc71; -fx-text-fill: white;" />

                    <Button fx:id="btnHistorico"
                            text="Histórico"
                            disable="true"
                            style="-fx-background-color: #95a5a6; -fx-text-fill: white;" />
                </HBox>

            </VBox>

            <!-- 📊 TABELA -->
            <VBox spacing="5">

                <Label text="Lista de Produtos"
                       style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" />

                <TableView fx:id="tabProdutos"
                           prefHeight="250"
                           maxHeight="250">

                    <columns>
                        <TableColumn fx:id="colID" text="ID" prefWidth="60"/>
                        <TableColumn fx:id="colCodBarras" text="Cód.Barras" prefWidth="120"/>
                        <TableColumn fx:id="colNome" text="Nome" prefWidth="150"/>
                        <TableColumn fx:id="colDescricao" text="Descrição" prefWidth="150"/>
                        <TableColumn fx:id="colCategoria" text="Categoria" prefWidth="100"/>
                        <TableColumn fx:id="colQuantidade" text="Qtd" prefWidth="80"/>
                    </columns>

                </TableView>

            </VBox>

            <!-- 📌 ÁREA EXTRA (remove espaço vazio) -->
            <HBox alignment="CENTER_LEFT"
                  style="-fx-background-color: #ecf0f1; -fx-padding: 10; -fx-background-radius: 8;">

                <Label text="💡 Dica: Selecione um produto e informe a quantidade para processar entrada ou saída de estoque."
                       style="-fx-text-fill: #7f8c8d;" />
            </HBox>

        </VBox>
    </center>

</BorderPane>