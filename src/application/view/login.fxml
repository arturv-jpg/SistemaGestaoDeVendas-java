<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<AnchorPane xmlns="http://javafx.com/javafx/24"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="application.controller.LoginController"
            prefWidth="400" prefHeight="500"
            style="-fx-background-color: linear-gradient(to bottom, #1e3c72, #2a5298);">

    <children>

        <VBox alignment="CENTER" spacing="20"
              layoutX="50" layoutY="80"
              prefWidth="300">

            <Label text="Sistema de Vendas"
                   style="-fx-font-size: 22px; -fx-text-fill: white; -fx-font-weight: bold;" />

            <Label text="Faça login para continuar"
                   style="-fx-text-fill: #dcdcdc;" />

            <!-- 🔧 CORRIGIDO AQUI -->
            <TextField fx:id="txtLogin"
                       promptText="Usuário"
                       prefHeight="40"
                       style="-fx-background-radius: 8; -fx-border-radius: 8;" />

            <PasswordField fx:id="txtSenha"
                           promptText="Senha"
                           prefHeight="40"
                           style="-fx-background-radius: 8; -fx-border-radius: 8;" />

            <Button text="Entrar"
                    fx:id="btnLogin"
                    prefHeight="40"
                    prefWidth="200"
                    onAction="#entrar"
                    style="-fx-background-color: #00c853; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;" />

            <Label fx:id="lblMensagem"
                   style="-fx-text-fill: #ff5252;" />

        </VBox>

    </children>
</AnchorPane>