<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns="http://javafx.com/javafx/24"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="application.controller.VendaController"
            prefHeight="450.0" prefWidth="650.0">

    <children>

        <!-- 🔹 TÍTULO -->
        <Label text="Sistema de Vendas"
               layoutX="0" layoutY="10"
               prefWidth="650"
               alignment="CENTER"
               style="-fx-background-color: #2c3e50; -fx-text-fill: white;">
            <font>
                <Font size="16"/>
            </font>
        </Label>

        <!-- 🔹 PRODUTO -->
        <Label text="Produto" layoutX="20" layoutY="50"/>
        <TextField fx:id="txtProduto" layoutX="20" layoutY="70" prefWidth="200"/>

        <Label text="Quantidade" layoutX="240" layoutY="50"/>
        <TextField fx:id="txtQtd" layoutX="240" layoutY="70" prefWidth="80"/>

        <Button text="Adicionar"
                layoutX="340" layoutY="70"
                prefWidth="120"
                style="-fx-background-color: #27ae60; -fx-text-fill: white;"
                onAction="#adicionarItem"/>

        <!-- 🔹 CLIENTE -->
        <Label text="Cliente" layoutX="20" layoutY="110"/>
        <ComboBox fx:id="cbCliente"
                  layoutX="20" layoutY="130"
                  prefWidth="300"
                  promptText="Selecione o cliente"/>

        <!-- 🔹 TABELA -->
        <TableView fx:id="tabItens"
                   layoutX="20" layoutY="170"
                   prefWidth="600" prefHeight="180">

            <columns>
                <TableColumn fx:id="colNome" text="Produto" prefWidth="250"/>
                <TableColumn fx:id="colQtd" text="Quantidade" prefWidth="120"/>
                <TableColumn fx:id="colPreco" text="Preço Unit." prefWidth="150"/>
            </columns>

        </TableView>

        <!-- 🔹 TOTAL -->
        <Label fx:id="lblTotal"
               layoutX="20" layoutY="360"
               text="Total: R$ 0.00"
               style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

        <!-- 🔹 BOTÕES -->
        <Button text="Finalizar Venda"
                layoutX="20" layoutY="390"
                prefWidth="180"
                style="-fx-background-color: #2980b9; -fx-text-fill: white;"
                onAction="#finalizarVenda"/>

        <Button text="Cancelar Venda"
                layoutX="220" layoutY="390"
                prefWidth="180"
                style="-fx-background-color: #c0392b; -fx-text-fill: white;"
                onAction="#cancelarVenda"/>
                
        <Button text="Cancelar Última Venda"
        layoutX="420" layoutY="390"
        prefWidth="180"
        style="-fx-background-color: #e67e22; -fx-text-fill: white;"
        onAction="#cancelarUltimaVenda"/>

    </children>
</AnchorPane>